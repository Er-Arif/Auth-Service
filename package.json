{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Production-ready reusable OTP authentication service",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/worker.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "openapi:generate": "node src/openapi/generate-openapi.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "test": "node --experimental-test-isolation=none --test \"tests/**/*.test.js\"",
    "test:smoke": "node tests/run-tests.js",
    "test:ci": "npm run lint && npm run format:check && npm run test && npm run test:smoke && npm run openapi:generate"
  },
  "keywords": [
    "otp",
    "auth",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.2.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.1.0",
    "nodemailer": "^8.0.5",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "prisma": "^6.6.0",
    "supertest": "^7.1.0",
    "vitest": "^3.1.1"
  }
}
