NODE_ENV=development
PORT=3000
API_BASE_PATH=/api/v1
CORS_ORIGIN=*
TRUST_PROXY=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_service?schema=public
JWT_ACCESS_SECRET=replace-with-long-access-secret
JWT_ACCESS_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
OTP_HASH_SECRET=replace-with-long-otp-secret
TOKEN_HASH_SECRET=replace-with-long-refresh-token-secret
APP_KEY_SALT_ROUNDS=10
INTERNAL_ADMIN_KEY=replace-with-internal-admin-key
EMAIL_FROM=no-reply@example.com
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
DEFAULT_EMAIL_PROVIDER=smtp
DEFAULT_DELIVERY_CHANNEL=mock
MSG91_AUTH_KEY=
MSG91_SMS_SENDER_ID=
MSG91_SMS_ROUTE=4
MSG91_SMS_COUNTRY=91
MSG91_SMS_BASE_URL=https://api.msg91.com
MSG91_SMS_TIMEOUT_MS=10000
ENABLE_DEV_OTP_LOG=true
ENABLE_BACKGROUND_JOBS=false
CLEANUP_CRON_SCHEDULE=0 */6 * * *
OTP_RETENTION_HOURS=24
REVOKED_TOKEN_RETENTION_DAYS=30
OPENAPI_OUTPUT_PATH=./openapi.json
